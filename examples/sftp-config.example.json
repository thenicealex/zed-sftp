{
  "name": "Production Server",
  "protocol": "sftp",
  "host": "example.com",
  "port": 22,
  "username": "deploy",
  "privateKeyPath": "~/.ssh/id_rsa",
  "hostFingerprint": "SHA256:base64-encoded-host-key-fingerprint",
  "remotePath": "/var/www/html",
  "uploadOnSave": true,
  "ignore": [
    ".git",
    ".vscode",
    ".zed",
    "node_modules",
    ".DS_Store",
    "*.log"
  ],
  "concurrency": 4,
  "connectTimeout": 10000,
  "passphrase": null
}
